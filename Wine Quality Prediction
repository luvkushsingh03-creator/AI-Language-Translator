        "    print(f\"Confidence         : {confidence:.2f}%\")\n",
        "    print(f\"Probability (BAD)  : {proba[0]*100:.2f}%\")\n",
        "    print(f\"Probability (GOOD) : {proba[1]*100:.2f}%\")\n",
        "    print(\"------------------------------\")\n",
        "\n",
        "    return label, proba\n",
        "\n",
        "\n",
        "# Run this cell to input a new wine sample and get a prediction:\n",
