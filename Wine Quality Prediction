        "print(final_result[\"confusion_matrix\"])\n",
        "print(\"=\" * 60)\n",
        "\n",
        "\n",
        "# --- Cell 16: PREDICT ON NEW WINE DATA (User Input) ---\n",
        "def predict_new_wine(model, feature_columns):\n",
